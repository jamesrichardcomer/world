# 1. Ignore everything
*

# 2. But allow Git to look inside folders (Critical step!)
!*/

# 3. Un-ignore (keep) Markdown files
!*.md

# 4. Un-ignore (keep) newly requested file types
!*.json
!*.css
!*.sh
!*.canvas

# 5. Un-ignore the .gitignore file itself (so you can edit it later)
!.gitignore

# Keep local git metadata out of sync and out of commits
.git.nosync
.git *
